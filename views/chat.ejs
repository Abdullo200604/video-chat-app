<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PDP Chat Application</title>
    <link rel="stylesheet" href="styles.css">
</head>
<body>
    <div class="container">
        <div class="video-container">
            <video id="local-video" autoplay muted></video>
            <video id="remote-video" autoplay></video>
        </div>
        <div class="chat-panel">
            <div class="messages">
                <!-- Chat messages will be dynamically inserted here -->
            </div>
            <input type="text" id="chat-input" placeholder="Type your message...">
            <button id="send-button">Send</button>
        </div>
        <div class="effects-panel">
            <button id="effect-button">Effects</button>
            <div class="effects-list">
                <!-- Effects will be dynamically listed here -->
            </div>
        </div>
        <div class="share-modal" id="share-modal">
            <div class="modal-content">
                <span class="close-button">&times;</span>
                <h2>Share this chat</h2>
                <input type="text" id="share-link" value="http://example.com/chat" readonly>
                <button id="copy-button">Copy Link</button>
            </div>
        </div>
    </div>
    <script src="script.js"></script>
</body>
</html>
