<!DOCTYPE html>
<html lang="uz">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
    <title>Majlisga kirish – PDP Chat</title>
    <link rel="icon" type="image/png" href="/logo.png">
    <link rel="stylesheet" href="/lobby.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
    <script src="/socket.io/socket.io.js"></script>
</head>

<body>

    <!-- NAV -->
    <nav class="lobby-nav">
        <a href="/" class="nav-logo">
            <img src="/logo.png" alt="PDP Logo" class="logo-img">
            <span>PDP <strong>Chat</strong></span>
        </a>
    </nav>

    <main class="lobby-main">

        <!-- LEFT: Camera preview -->
        <div class="lobby-preview">
            <div class="camera-preview" id="cameraPreview">
                <video id="previewVideo" autoplay playsinline muted></video>
                <div class="camera-off-state" id="cameraOffState">
                    <div class="cam-avatar" id="camAvatarDisplay">
                        <span id="avatarInitial">?</span>
                    </div>
                </div>
                <div class="preview-controls">
                    <button class="preview-btn" id="previewMicBtn" onclick="togglePreviewMic()" title="Mikrofon">
                        <i class="fas fa-microphone"></i>
                    </button>
                    <button class="preview-btn" id="previewCamBtn" onclick="togglePreviewCam()" title="Kamera">
                        <i class="fas fa-video"></i>
                    </button>
                </div>
            </div>
            <div class="device-check" id="deviceCheck">
                <span class="device-ok"><i class="fas fa-circle-check"></i> Kamera va mikrofon tayyor</span>
            </div>
        </div>

        <!-- RIGHT: Join form -->
        <div class="lobby-form-area">
            <h1 class="lobby-title">Majlisga qo'shilish</h1>
            <p class="lobby-subtitle">Nomingizni kiriting va qo'shiling</p>

            <div class="form-group">
                <label class="form-label">Ismingiz</label>
                <input type="text" id="nameInput" class="form-input" placeholder="Ism Familiya" maxlength="40"
                    autofocus />
            </div>

            <div class="form-group" style="display:flex; gap:10px;">
                <div style="flex:1;">
                    <label class="form-label">Kamera</label>
                    <select id="lobbyCamSelect" class="form-input" style="padding:10px; font-size:14px;"
                        onchange="switchLobbyCam(this.value)"></select>
                </div>
                <div style="flex:1;">
                    <label class="form-label">Mikrofon</label>
                    <select id="lobbyMicSelect" class="form-input" style="padding:10px; font-size:14px;"
                        onchange="switchLobbyMic(this.value)"></select>
                </div>
            </div>

            <div id="permissionDenied" class="permission-warning hidden">
                <i class="fas fa-exclamation-triangle"></i>
                Kamera yoki mikrofon ruxsati rad etildi. Ism kiriting va davom eting.
            </div>

            <button class="btn-join-meeting" id="joinBtn" onclick="joinMeeting()" disabled>
                <i class="fas fa-sign-in-alt"></i>
                Qo'shilish
            </button>

            <div class="join-info">
                <i class="fas fa-info-circle"></i>
                Qo'shilganda kamera va mikrofon so'raladi.
            </div>
        </div>

    </main>

    <!-- Waiting Overlay -->
    <div class="lobby-waiting-overlay hidden" id="waitingOverlay">
        <div class="waiting-card">
            <div class="waiting-spinner"></div>
            <h3>Iltimos, kuting...</h3>
            <p>Mezbon sizni qabul qilishini kutilmoqda.</p>
            <button class="btn-cancel-knock" onclick="cancelKnock()">Bekor qilish</button>
        </div>
    </div>

    <script>
        const ROOM_ID = window.location.pathname.split('/').pop();
        let localStream = null;
        let micEnabled = true;
        let camEnabled = true;
        let currCamId = null;
        let currMicId = null;

        // ── Get camera/mic ──────────────────────────
        async function initMedia() {
            try {
                localStream = await navigator.mediaDevices.getUserMedia({ video: true, audio: true });
                const vid = document.getElementById('previewVideo');
                vid.srcObject = localStream;
                vid.style.display = 'block';
                document.getElementById('cameraOffState').style.display = 'none';
                await loadLobbyDevices();
            } catch (e) {
                document.getElementById('permissionDenied').classList.remove('hidden');
                document.getElementById('deviceCheck').innerHTML =
                    '<span class="device-warn"><i class="fas fa-exclamation-triangle"></i> Qurilma ruxsati rad etildi</span>';
                document.getElementById('previewVideo').style.display = 'none';
            }
        }

        async function loadLobbyDevices() {
            const devs = await navigator.mediaDevices.enumerateDevices().catch(() => []);
            const camSel = document.getElementById('lobbyCamSelect');
            const micSel = document.getElementById('lobbyMicSelect');
            camSel.innerHTML = '';
            micSel.innerHTML = '';
            devs.filter(d => d.kind === 'videoinput').forEach(d => {
                const o = document.createElement('option');
                o.value = d.deviceId; o.textContent = d.label || 'Kamera';
                camSel.appendChild(o);
                if (!currCamId) currCamId = d.deviceId;
            });
            devs.filter(d => d.kind === 'audioinput').forEach(d => {
                const o = document.createElement('option');
                o.value = d.deviceId; o.textContent = d.label || 'Mikrofon';
                micSel.appendChild(o);
                if (!currMicId) currMicId = d.deviceId;
            });
            if (currCamId) camSel.value = currCamId;
            if (currMicId) micSel.value = currMicId;
        }

        async function switchLobbyCam(deviceId) {
            currCamId = deviceId;
            await restartLobbyMedia();
        }

        async function switchLobbyMic(deviceId) {
            currMicId = deviceId;
            await restartLobbyMedia();
        }

        async function restartLobbyMedia() {
            if (localStream) {
                localStream.getTracks().forEach(t => t.stop());
            }
            const constraints = {
                video: camEnabled ? (currCamId ? { deviceId: { exact: currCamId } } : true) : false,
                audio: micEnabled ? (currMicId ? { deviceId: { exact: currMicId } } : true) : false
            };
            try {
                localStream = await navigator.mediaDevices.getUserMedia(constraints);
                const vid = document.getElementById('previewVideo');
                vid.srcObject = localStream;
                vid.style.display = camEnabled ? 'block' : 'none';
            } catch (e) { }
        }

        function togglePreviewMic() {
            micEnabled = !micEnabled;
            // Always rely on track enabling/disabling instead of full restarts to be faster
            if (localStream) localStream.getAudioTracks().forEach(t => t.enabled = micEnabled);
            const btn = document.getElementById('previewMicBtn');
            btn.innerHTML = micEnabled ? '<i class="fas fa-microphone"></i>' : '<i class="fas fa-microphone-slash"></i>';
            btn.classList.toggle('btn-off', !micEnabled);
        }

        function togglePreviewCam() {
            camEnabled = !camEnabled;
            if (localStream) localStream.getVideoTracks().forEach(t => t.enabled = camEnabled);
            const btn = document.getElementById('previewCamBtn');
            btn.innerHTML = camEnabled ? '<i class="fas fa-video"></i>' : '<i class="fas fa-video-slash"></i>';
            btn.classList.toggle('btn-off', !camEnabled);
            document.getElementById('cameraOffState').style.display = camEnabled ? 'none' : 'flex';
            document.getElementById('previewVideo').style.display = camEnabled ? 'block' : 'none';
        }

        // ── Name input ──────────────────────────────
        document.getElementById('nameInput').addEventListener('input', function () {
            const val = this.value.trim();
            document.getElementById('joinBtn').disabled = val.length < 2;
            const initial = val.charAt(0).toUpperCase() || '?';
            document.getElementById('avatarInitial').textContent = initial;
        });

        // ── Socket & Security ──────────────────────
        const socket = io();
        let isKnocking = false;

        socket.on('waiting-approval', () => {
            isKnocking = true;
            document.getElementById('waitingOverlay').classList.remove('hidden');
        });

        socket.on('join-approved', () => {
            const name = document.getElementById('nameInput').value.trim();
            sessionStorage.setItem('pdp_name', name);
            sessionStorage.setItem('pdp_mic', micEnabled);
            sessionStorage.setItem('pdp_cam', camEnabled);
            sessionStorage.setItem('pdp_cam_id', currCamId || '');
            sessionStorage.setItem('pdp_mic_id', currMicId || '');
            window.location.href = '/meeting/' + ROOM_ID;
        });

        socket.on('join-denied', () => {
            isKnocking = false;
            document.getElementById('waitingOverlay').classList.add('hidden');
            alert('Mezbon kirishingizni rad etdi.');
        });

        socket.on('force-kick', (msg) => {
            alert(msg || 'Kirish imkonsiz.');
            window.location.href = '/';
        });

        // ── Boot ────────────────────────────────────
        initMedia();
        checkAuth();

        // Overwrite joinMeeting for Knocking support
        function joinMeeting() {
            const name = document.getElementById('nameInput').value.trim();
            if (name.length < 2) return;

            // Emit join request
            socket.emit('join-room', ROOM_ID, 'lobby-' + Math.random().toString(36).substr(2, 9), name);
        }

        function cancelKnock() {
            window.location.reload();
        }
    </script>
    <style>
        .lobby-waiting-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.8);
            z-index: 999;
            display: flex;
            align-items: center;
            justify-content: center;
            backdrop-filter: blur(8px);
        }

        .waiting-card {
            background: white;
            padding: 30px;
            border-radius: 16px;
            text-align: center;
            max-width: 400px;
            width: 90%;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 15px;
        }

        .waiting-spinner {
            width: 50px;
            height: 50px;
            border: 4px solid #f3f3f3;
            border-top: 4px solid #1a73e8;
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }

        @keyframes spin {
            0% {
                transform: rotate(0deg);
            }

            100% {
                transform: rotate(360deg);
            }
        }

        .btn-cancel-knock {
            background: #f1f3f4;
            border: none;
            padding: 10px 20px;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 500;
        }
    </style>
</body>

</html>