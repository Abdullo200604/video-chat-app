<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Suhbat Ilovasi | Google Meet Clone</title>
    <!-- CSS -->
    <link rel="stylesheet" href="style.css">
    <!-- Socket.io -->
    <script src="/socket.io/socket.io.js"></script>
    <!-- PeerJS -->
    <script src="https://unpkg.com/peerjs@1.5.2/dist/peerjs.min.js"></script>
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
    <script>
        const ROOM_ID = "<%= roomId %>";
    </script>
</head>
<body>
    <div class="main-container">
        <!-- Video qismi -->
        <div class="main-left">
            <div class="main-videos">
                <div id="video-grid"></div>
            </div>
            <div class="main-controls">
                <div class="main-controls-block">
                    <div class="main-controls-button" id="muteButton" onclick="muteUnmute()">
                        <i class="fas fa-microphone"></i>
                        <span>Ovoz</span>
                    </div>
                    <div class="main-controls-button" id="playPauseVideo" onclick="playStop()">
                        <i class="fas fa-video"></i>
                        <span>Kamera</span>
                    </div>
                </div>
                
                <div class="main-controls-block">
                    <div class="main-controls-button leave-meeting" onclick="window.close()">
                        <span class="leave-text">Tark etish</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Chat qismi -->
        <div class="main-right">
            <div class="main-header">
                <h6>Chat xabarlari</h6>
            </div>
            <div class="main-chat-window">
                <ul class="messages"></ul>
            </div>
            <div class="main-message-container">
                <input id="chat_message" type="text" placeholder="Xabar yozing so'ng Enter bosing...">
            </div>
        </div>
    </div>
    
    <script src="script.js"></script>
</body>
</html>
