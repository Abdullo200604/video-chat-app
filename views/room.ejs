<!DOCTYPE html>
<html lang="uz">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>PDP Chat – Majlis</title>
    <link rel="icon" type="image/png" href="/logo.png">
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="/games.css">
    <script src="/socket.io/socket.io.js"></script>
    <script src="https://unpkg.com/peerjs@1.5.2/dist/peerjs.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
    <script>const ROOM_ID = "<%= roomId %>";</script>
</head>

<body class="meeting-body">

    <!-- ── HEADER ── -->
    <header class="meeting-header">
        <div class="header-left">
            <a href="/" class="nav-logo">
                <img src="/logo.png" alt="PDP Logo" class="logo-img">
                <span class="logo-text">PDP <strong>Chat</strong></span>
            </a>
            <div class="meeting-timer" id="meetingTimer">00:00</div>
            <div class="rec-indicator hidden" id="recIndicator">
                <span class="rec-dot"></span> REC
            </div>
        </div>
        <div class="header-right-group">
            <div class="conn-quality" id="connQuality" title="Ulanish sifati">
                <i class="fas fa-signal"></i>
                <span id="connQualityText">Yaxshi</span>
            </div>
            <div class="private-badge hidden" id="privateBadge" title="Maxfiy suhbat yoqilgan">
                <i class="fas fa-user-shield"></i>
                <span>Private</span>
            </div>
            <div class="meeting-code">
                <span id="meetingCodeText"></span>
                <button class="icon-btn" onclick="copyMeetingLink()" title="Havolani nusxalash">
                    <i class="fas fa-copy"></i>
                </button>
            </div>
        </div>
    </header>

    <!-- ── MAIN VIDEO AREA ── -->
    <main class="video-area" id="videoArea">
        <div class="video-grid" id="videoGrid"></div>
        <div class="privacy-watermark hidden" id="privacyWatermark"></div>
        <div class="away-overlay hidden" id="awayOverlay">
            <i class="fas fa-eye-slash"></i>
            <p>Xavfsizlik tizimi: Majlis xiralashtirildi</p>
            <span>Majlisga qaytish uchun oynaga bosing</span>
        </div>
    </main>

    <!-- ── REACTION OVERLAY ── -->
    <div class="reactions-overlay" id="reactionsOverlay"></div>

    <!-- ── BOTTOM CONTROL BAR ── -->
    <div class="control-bar" id="controlBar">
        <div class="ctrl-group">
            <button class="ctrl-btn" id="micBtn" onclick="toggleMic()" title="Mikrofon">
                <i class="fas fa-microphone"></i>
                <span>Mikrofon</span>
            </button>
            <button class="ctrl-btn" id="camBtn" onclick="toggleCam()" title="Kamera">
                <i class="fas fa-video"></i>
                <span>Kamera</span>
            </button>
            <button class="ctrl-btn" id="screenBtn" onclick="toggleScreenShare()" title="Ekran ulashish">
                <i class="fas fa-desktop"></i>
                <span>Ekran</span>
            </button>
        </div>
        <div class="ctrl-group">
            <button class="ctrl-btn" id="recordBtn" onclick="toggleRecording()" title="Yozib olish">
                <i class="fas fa-record-vinyl"></i>
                <span>Yozish</span>
            </button>
            <button class="ctrl-btn" id="blurBtn" onclick="toggleVirtualBlur()" title="Fon Blur">
                <i class="fas fa-user-shield"></i>
                <span>Fon Blur</span>
            </button>
            <button class="ctrl-btn" id="effectsBtn" onclick="togglePanel('effects')" title="Effektlar">
                <i class="fas fa-magic"></i>
                <span>Effektlar</span>
            </button>
            <button class="ctrl-btn" id="gamesBtn" onclick="window.location.href='https://chat.pdpedu.uz/random'"
                title="O'yinlar">
                <i class="fas fa-gamepad"></i>
                <span>O'yinlar</span>
            </button>
            <button class="ctrl-btn" id="chatBtn" onclick="togglePanel('chat')" title="Chat">
                <i class="fas fa-comment"></i>
                <span>Chat</span>
                <span class="badge" id="chatBadge"></span>
            </button>
            <button class="ctrl-btn" id="participantsBtn" onclick="togglePanel('participants')" title="Ishtirokchilar">
                <i class="fas fa-users"></i>
                <span>Ishtirokchilar</span>
                <span class="badge badge-count" id="participantCount">1</span>
            </button>
            <button class="ctrl-btn" id="reactionsBtn" onclick="toggleReactionMenu()" title="Reaksiyalar">
                <i class="fas fa-smile"></i>
                <span>Reaksiya</span>
            </button>
            <button class="ctrl-btn" id="handBtn" onclick="raiseHand()" title="Qo'l ko'tarish">
                <i class="fas fa-hand-paper"></i>
                <span>Qo'l</span>
            </button>
            <button class="ctrl-btn host-only hidden" id="theaterBtn" onclick="toggleTheaterMode()"
                title="Theater Mode">
                <i class="fas fa-film"></i>
                <span>Theater</span>
            </button>
            <button class="ctrl-btn host-only hidden" id="hostPanelBtn" onclick="togglePanel('host')" title="Boshqaruv">
                <i class="fas fa-shield-alt"></i>
                <span>Boshqaruv</span>
            </button>
        </div>
        <div class="ctrl-group">
            <button class="ctrl-btn" onclick="togglePanel('settings')" title="Sozlamalar">
                <i class="fas fa-cog"></i>
                <span>Sozlamalar</span>
            </button>
            <button class="ctrl-btn leave-btn" onclick="confirmLeave()" title="Chiqish">
                <i class="fas fa-phone-slash"></i>
                <span>Chiqish</span>
            </button>
        </div>
    </div>

    <!-- ── REACTION PICKER ── -->
    <div class="reaction-menu hidden" id="reactionMenu">
        <button onclick="sendReaction('👍')">👍</button>
        <button onclick="sendReaction('❤️')">❤️</button>
        <button onclick="sendReaction('😂')">😂</button>
        <button onclick="sendReaction('👏')">👏</button>
        <button onclick="sendReaction('🔥')">🔥</button>
        <button onclick="sendReaction('🎉')">🎉</button>
        <button onclick="sendReaction('😮')">😮</button>
        <button onclick="sendReaction('🙁')">🙁</button>
    </div>

    <!-- ══════════════ SIDE PANELS ══════════════ -->

    <!-- Chat Panel -->
    <div class="side-panel" id="chatPanel">
        <div class="panel-hdr">
            <span>💬 Chat</span>
            <button class="panel-close" onclick="togglePanel('chat')"><i class="fas fa-times"></i></button>
        </div>
        <div class="chat-messages" id="chatMessages"></div>
        <div class="chat-input-area" id="chatInputArea">
            <input id="chatInput" type="text" placeholder="Xabar yozing...">
            <button onclick="sendMessage()"><i class="fas fa-paper-plane"></i></button>
        </div>
        <div class="chat-disabled-msg hidden" id="chatDisabledMsg">
            <i class="fas fa-lock"></i> Mezbon xabar yuborishni o'chirdi
        </div>
    </div>

    <!-- Participants Panel -->
    <div class="side-panel" id="participantsPanel">
        <div class="panel-hdr">
            <span>👥 Ishtirokchilar</span>
            <button class="panel-close" onclick="togglePanel('participants')"><i class="fas fa-times"></i></button>
        </div>
        <div class="participants-list" id="participantsList"></div>
    </div>

    <!-- Effects Panel -->
    <div class="side-panel" id="effectsPanel">
        <div class="panel-hdr">
            <span>✨ Effektlar</span>
            <button class="panel-close" onclick="togglePanel('effects')"><i class="fas fa-times"></i></button>
        </div>
        <div class="effects-grid">
            <div class="effect-card active" id="effect-none" onclick="applyEffect('none')">
                <div class="effect-preview effect-none-preview"><i class="fas fa-ban"></i></div>
                <span>None</span>
            </div>
            <div class="effect-card" id="effect-blur" onclick="applyEffect('blur')">
                <div class="effect-preview effect-blur-preview"><i class="fas fa-wind"></i></div>
                <span>Blur</span>
            </div>
            <div class="effect-card" id="effect-grayscale" onclick="applyEffect('grayscale')">
                <div class="effect-preview effect-grayscale-preview"><i class="fas fa-adjust"></i></div>
                <span>Gray</span>
            </div>
            <div class="effect-card" id="effect-sepia" onclick="applyEffect('sepia')">
                <div class="effect-preview effect-sepia-preview"><i class="fas fa-leaf"></i></div>
                <span>Sepia</span>
            </div>
            <div class="effect-card" id="effect-invert" onclick="applyEffect('invert')">
                <div class="effect-preview effect-invert-preview"><i class="fas fa-eye-dropper"></i></div>
                <span>Invert</span>
            </div>
            <div class="effect-card" id="effect-warm" onclick="applyEffect('warm')">
                <div class="effect-preview effect-warm-preview"><i class="fas fa-sun"></i></div>
                <span>Warm</span>
            </div>
        </div>
    </div>

    <!-- Games Panel -->
    <div class="side-panel" id="gamesPanel">
        <div class="panel-header">
            <h3>🎮 O'yinlar</h3>
            <button class="close-panel" onclick="togglePanel('games')"><i class="fas fa-times"></i></button>
        </div>
        <div class="panel-body">
            <div id="gamesDashboard">
                <p style="color:var(--text-muted); font-size: 0.9rem; margin-bottom: 1rem;">Birorta o'yinni tanlang va
                    do'stlar bilan o'ynang.</p>
                <div class="game-launch-list">
                    <button class="game-launch-btn" onclick="launchGame('tictactoe')">
                        <i class="fas fa-times"></i> Tic-Tac-Toe
                    </button>
                    <button class="game-launch-btn" onclick="launchGame('rps')">
                        <i class="fas fa-hand-scissors"></i> Tosh, Qaychi, Qogoz
                    </button>
                    <button class="game-launch-btn" onclick="launchGame('snake')">
                        <i class="fas fa-staff-snake"></i> Multiplayer Snake
                    </button>
                    <button class="game-launch-btn" onclick="launchGame('chess')">
                        <i class="fas fa-chess-knight"></i> Sodda Shaxmat
                    </button>
                </div>
            </div>
            <div id="activeGameArea" class="hidden">
                <!-- Game content dynamic -->
            </div>
        </div>
    </div>

    <!-- Host Panel -->
    <div class="side-panel" id="hostPanel">
        <div class="panel-hdr">
            <span>🛡️ Majlis boshqaruvi</span>
            <button class="panel-close" onclick="togglePanel('host')"><i class="fas fa-times"></i></button>
        </div>
        <div class="host-panel-body">
            <h4 class="section-label">Kirish turi</h4>
            <select id="accessTypeSelect" class="host-select" onchange="updateSetting('accessType', this.value)">
                <option value="open">Ochiq – har kim kiradi</option>
                <option value="trusted">Trusted – taklif qilinganlar</option>
                <option value="request">So'rov – ruxsat kerak</option>
            </select>

            <h4 class="section-label">Ruxsatlar</h4>
            <div class="perm-list">
                <label class="toggle-row">
                    <span><i class="fas fa-desktop"></i> Ekran ulashish</span>
                    <input type="checkbox" id="perm-screenShare" checked
                        onchange="updatePerm('screenShare', this.checked)">
                </label>
                <label class="toggle-row">
                    <span><i class="fas fa-smile"></i> Reaksiyalar</span>
                    <input type="checkbox" id="perm-reactions" checked onchange="updatePerm('reactions', this.checked)">
                </label>
                <label class="toggle-row">
                    <span><i class="fas fa-microphone"></i> Ishtirokchi mik</span>
                    <input type="checkbox" id="perm-participantMic" checked
                        onchange="updatePerm('participantMic', this.checked)">
                </label>
                <label class="toggle-row">
                    <span><i class="fas fa-video"></i> Ishtirokchi kamera</span>
                    <input type="checkbox" id="perm-participantCamera" checked
                        onchange="updatePerm('participantCamera', this.checked)">
                </label>
                <label class="toggle-row">
                    <span><i class="fas fa-comment"></i> Chat</span>
                    <input type="checkbox" id="perm-chat" checked onchange="toggleChatForAll(this.checked)">
                </label>
            </div>

            <h4 class="section-label">Xona xavfsizligi</h4>
            <div class="perm-list">
                <label class="toggle-row">
                    <span><i class="fas fa-lock"></i> Majlisni qulflash</span>
                    <input type="checkbox" id="lockRoomCheck" onchange="toggleRoomLock(this.checked)">
                </label>
                <button class="btn-primary-sm full-width mt-10" onclick="muteAllParticipants()">
                    <i class="fas fa-microphone-slash"></i> Hammada mikni o'chirish
                </button>
            </div>

            <h4 class="section-label">Ishtirokchilar</h4>
            <div class="participants-list host-list" id="hostParticipantsList"></div>
        </div>
    </div>

    <!-- Settings Panel -->
    <div class="side-panel" id="settingsPanel">
        <div class="panel-hdr">
            <span>⚙️ Sozlamalar</span>
            <button class="panel-close" onclick="togglePanel('settings')"><i class="fas fa-times"></i></button>
        </div>
        <div class="host-panel-body">
            <h4 class="section-label">Kamera</h4>
            <select id="cameraSelect" class="host-select" onchange="switchCamera(this.value)"></select>
            <h4 class="section-label">Mikrofon</h4>
            <select id="micSelect" class="host-select" onchange="switchMic(this.value)"></select>
            <h4 class="section-label">Dinamik (Speaker)</h4>
            <select id="speakerSelect" class="host-select" onchange="switchSpeaker(this.value)"></select>
        </div>
    </div>

    <!-- ══════════════ THEATER MODE ══════════════ -->
    <div class="theater-overlay" id="theaterOverlay">
        <div class="theater-bg">
            <div class="theater-ceiling"></div>
            <div class="curtain-left">
                <div class="curtain-fold"></div>
            </div>
            <div class="curtain-right">
                <div class="curtain-fold"></div>
            </div>
            <div class="theater-seats">
                <div class="seat-row" style="--r:1"></div>
                <div class="seat-row" style="--r:2"></div>
                <div class="seat-row" style="--r:3"></div>
                <div class="seat-row" style="--r:4"></div>
                <div class="seat-row" style="--r:5"></div>
                <div class="seat-row" style="--r:6"></div>
            </div>
            <div class="stage-light left-light"></div>
            <div class="stage-light right-light"></div>
        </div>
        <div class="theater-content">
            <div class="proscenium-arch">
                <div class="theater-screen-wrapper" id="theaterScreenWrapper" onclick="enterFocusMode()">
                    <div class="screen-shine"></div>
                    <div class="theater-screen-video" id="theaterMainVideo"></div>
                    <div class="screen-click-hint">
                        <i class="fas fa-expand-arrows-alt"></i><span>Kattalashtirish</span>
                    </div>
                </div>
            </div>
            <div class="theater-avatars" id="theaterAvatars"></div>
        </div>
        <div class="theater-controls">
            <button class="ctrl-btn" id="t-micBtn" onclick="toggleMic()"><i
                    class="fas fa-microphone"></i><span>Ovoz</span></button>
            <button class="ctrl-btn" id="t-camBtn" onclick="toggleCam()"><i
                    class="fas fa-video"></i><span>Kamera</span></button>
            <button class="ctrl-btn" onclick="togglePanel('chat')"><i class="fas fa-comment"></i><span>Chat</span><span
                    class="badge" id="t-chatBadge"></span></button>
            <button class="ctrl-btn host-only hidden" id="t-theaterBtn" onclick="toggleTheaterMode()"><i
                    class="fas fa-times-circle"></i><span>Chiqish</span></button>
            <button class="ctrl-btn leave-btn" onclick="confirmLeave()"><i
                    class="fas fa-phone-slash"></i><span>Chiqish</span></button>
        </div>
    </div>

    <!-- Focus Mode -->
    <div class="focus-overlay" id="focusOverlay" onclick="exitFocusMode()">
        <div class="focus-inner" id="focusInner" onclick="event.stopPropagation()">
            <button class="focus-close-btn" onclick="exitFocusMode()"><i class="fas fa-times"></i></button>
            <div class="focus-video-container" id="focusVideoContainer"></div>
        </div>
    </div>

    <!-- Leave Confirm Modal -->
    <div class="modal-overlay hidden" id="leaveModal">
        <div class="confirm-modal">
            <h3>Majlisdan chiqasizmi?</h3>
            <p>Majlisni tark etsangiz boshqalar davom etadi.</p>
            <div class="confirm-actions">
                <button class="btn-cancel" onclick="document.getElementById('leaveModal').classList.add('hidden')">Bekor
                    qilish</button>
                <button class="btn-leave-confirm" onclick="leaveMeeting()">Chiqish</button>
            </div>
        </div>
    </div>

    <!-- Toast notification -->
    <div class="toast-container" id="toastContainer"></div>

    <!-- Join Request Modal (for Host) -->
    <div class="modal-overlay hidden" id="knockModal">
        <div class="confirm-modal">
            <h3 id="knockTitle">Kirish so'rovi</h3>
            <p id="knockMsg">Ishtirokchi majlisga kirishni so'ramoqda.</p>
            <div class="confirm-actions">
                <button class="btn-cancel" id="denyBtn">Deny</button>
                <button class="btn-leave-confirm" id="admitBtn" style="background:var(--green)">Admit</button>
            </div>
        </div>
    </div>

    <script src="/script.js"></script>
</body>

</html>