<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Suhbat Ilovasi | Video Chat</title>
    <link rel="stylesheet" href="style.css">
    <script src="/socket.io/socket.io.js"></script>
    <script src="https://unpkg.com/peerjs@1.5.2/dist/peerjs.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
    <script>
        const ROOM_ID = "<%= roomId %>";
    </script>
</head>

<body>
    <div class="main-container">

        <!-- ═══ Video qismi (chap) ═══ -->
        <div class="main-left">
            <div class="main-videos">
                <div id="video-grid"></div>
            </div>

            <!-- Boshqaruv tugmalari -->
            <div class="main-controls">

                <!-- Blok 1: Mikrofon + Kamera -->
                <div class="main-controls-block">
                    <div class="main-controls-button" id="muteButton" onclick="muteUnmute()">
                        <i class="fas fa-microphone"></i>
                        <span>Ovoz</span>
                    </div>
                    <div class="main-controls-button" id="playPauseVideo" onclick="playStop()">
                        <i class="fas fa-video"></i>
                        <span>Kamera</span>
                    </div>
                </div>

                <!-- Blok 2: Chat + Effekt -->
                <div class="main-controls-block">
                    <div class="main-controls-button" id="chatToggleBtn" onclick="togglePanel('chat')">
                        <i class="fas fa-comment"></i>
                        <span>Chat</span>
                        <span class="badge" id="chatBadge"></span>
                    </div>
                    <div class="main-controls-button" id="effectsToggleBtn" onclick="togglePanel('effects')">
                        <i class="fas fa-magic"></i>
                        <span>Effekt</span>
                    </div>
                </div>

                <!-- Blok 3: Tark etish -->
                <div class="main-controls-block">
                    <div class="main-controls-button leave-meeting" onclick="window.close()">
                        <span class="leave-text">Tark etish</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- ═══ Chat paneli (o'ng) ═══ -->
        <div class="side-panel" id="chatPanel">
            <div class="panel-header">
                <span>💬 Chat xabarlari</span>
                <button class="close-panel-btn" onclick="togglePanel('chat')"><i class="fas fa-times"></i></button>
            </div>
            <div class="main-chat-window">
                <ul class="messages"></ul>
            </div>
            <div class="main-message-container">
                <input id="chat_message" type="text" placeholder="Xabar yozing, Enter bosing...">
            </div>
        </div>

        <!-- ═══ Effektlar paneli (o'ng) ═══ -->
        <div class="side-panel" id="effectsPanel">
            <div class="panel-header">
                <span>✨ Video Effektlar</span>
                <button class="close-panel-btn" onclick="togglePanel('effects')"><i class="fas fa-times"></i></button>
            </div>
            <div class="effects-grid">
                <div class="effect-card active" id="effect-none" onclick="applyEffect('none')">
                    <div class="effect-preview effect-none-preview">
                        <i class="fas fa-user"></i>
                    </div>
                    <span>Asl ko'rinish</span>
                </div>
                <div class="effect-card" id="effect-blur" onclick="applyEffect('blur')">
                    <div class="effect-preview effect-blur-preview">
                        <i class="fas fa-user"></i>
                    </div>
                    <span>Blur (loyqa)</span>
                </div>
                <div class="effect-card" id="effect-grayscale" onclick="applyEffect('grayscale')">
                    <div class="effect-preview effect-grayscale-preview">
                        <i class="fas fa-user"></i>
                    </div>
                    <span>Kulrang</span>
                </div>
                <div class="effect-card" id="effect-sepia" onclick="applyEffect('sepia')">
                    <div class="effect-preview effect-sepia-preview">
                        <i class="fas fa-user"></i>
                    </div>
                    <span>Vintage</span>
                </div>
                <div class="effect-card" id="effect-invert" onclick="applyEffect('invert')">
                    <div class="effect-preview effect-invert-preview">
                        <i class="fas fa-user"></i>
                    </div>
                    <span>Teskari rang</span>
                </div>
                <div class="effect-card" id="effect-warm" onclick="applyEffect('warm')">
                    <div class="effect-preview effect-warm-preview">
                        <i class="fas fa-user"></i>
                    </div>
                    <span>Iliq rang</span>
                </div>
            </div>
        </div>

    </div>

    <script src="script.js"></script>
</body>

</html>